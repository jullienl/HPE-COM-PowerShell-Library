        <View>
            <Name>PreclaimValidation</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.License.Preclaim</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader>
                        <Label>SubscriptionKey</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>CanBeClaimed</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Message</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>WorkspaceId</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>WorkspaceName</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>ErrorCode</Label>
                    </TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
                    <TableRowEntry>
                        <TableColumnItems>
                            <TableColumnItem>
                                <PropertyName>subscriptionKey</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.canBeClaimed) {
                                        "Yes"
                                    } else {
                                        "No"
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.message -and $_.message.Length -gt 60) {
                                        $_.message.Substring(0, 57) + "..."
                                    } else {
                                        $_.message
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>workspaceId</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>workspaceName</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>errorCode</PropertyName>
                            </TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
            </TableControl>
        </View>

