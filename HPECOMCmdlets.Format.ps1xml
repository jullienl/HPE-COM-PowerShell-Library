        <!-- ===== OneView Appliance Settings Sections ===== -->

        <!-- Security: new format (OV 7.x+) — has allowSshAccess, enforceComplexPasswordEnabled, enableServiceAccess etc. -->
        <View>
            <Name>Settings</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.COM.Settings.OVE_APPLIANCE_SETTINGS.Security</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader><Label>AllowSSHAccess</Label></TableColumnHeader>
                    <TableColumnHeader><Label>EnforceComplexPwd</Label></TableColumnHeader>
                    <TableColumnHeader><Label>EnableServiceAccess</Label></TableColumnHeader>
                    <TableColumnHeader><Label>ProductImprovement</Label></TableColumnHeader>
                    <TableColumnHeader><Label>CertValidate</Label></TableColumnHeader>
                    <TableColumnHeader><Label>AutoDownloadCRL</Label></TableColumnHeader>
                    <TableColumnHeader><Label>CheckRevocation</Label></TableColumnHeader>
                    <TableColumnHeader><Label>AuditLogForwarding</Label></TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
                    <TableRowEntry>
                        <TableColumnItems>
                            <TableColumnItem><ScriptBlock>$_.allowSshAccess</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>if ($null -ne $_.enforceComplexPasswordEnabled) { $_.enforceComplexPasswordEnabled } else { $_.enforceComplexPasswords }</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.enableServiceAccess</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.productImprovement</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.certValidationConfig.validateCertificate</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.certValidationConfig.autoDownloadCRL</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.certValidationConfig.checkCertificateRevocation</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.auditLogForwarding.forwardingEnabled</ScriptBlock></TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
                <AutoSize/>
            </TableControl>
        </View>

        <!-- Security: VM OneView format — has allowLocalLogin, emergencyLocalLoginEnabled, twoFactorAuthenticationEnabled etc. -->
        <View>
            <Name>Settings</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.COM.Settings.OVE_APPLIANCE_SETTINGS.Security.VM</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader><Label>AllowLocalLogin</Label></TableColumnHeader>
                    <TableColumnHeader><Label>EmergencyLocalLogin</Label></TableColumnHeader>
                    <TableColumnHeader><Label>TwoFactorAuth</Label></TableColumnHeader>
                    <TableColumnHeader><Label>StrictTwoFactor</Label></TableColumnHeader>
                    <TableColumnHeader><Label>DefaultLoginDomain</Label></TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
                    <TableRowEntry>
                        <TableColumnItems>
                            <TableColumnItem><ScriptBlock>$_.allowLocalLogin</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.emergencyLocalLoginEnabled</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.twoFactorAuthenticationEnabled</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>$_.strictTwoFactorAuthentication</ScriptBlock></TableColumnItem>
                            <TableColumnItem><ScriptBlock>if ($_.defaultLoginDomain) { $_.defaultLoginDomain.name }</ScriptBlock></TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
                <AutoSize/>
            </TableControl>
        </View>

