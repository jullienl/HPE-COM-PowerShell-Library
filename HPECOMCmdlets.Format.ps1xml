                                    if($_.type -eq "PREDEFINED"){"Built-in"}                                
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if($_.supports_scope_groups -eq $true){"Supported"}
                                    elseif($_.supports_scope_groups -eq $false){"Not Supported"}
                                    else{"Unknown"}
                                </ScriptBlock>
                            </TableColumnItem>
