        <View>
            <Name>Detailed Locations</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.Location</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader>
                        <Label>Name</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>ValidatedByName</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>ValidatedByEmail</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>City</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Country</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Latitude</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Longitude</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>ValidationStatus</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>ExpirationDate</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
                    <TableRowEntry>
                        <TableColumnItems>
                            <TableColumnItem>
                                <ScriptBlock>"{0} " -f $_.name</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>validatedByName</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>validatedByEmail</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>city</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>country</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>lat</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>lng</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    If ($_.validated -eq $true) {
                                        "Valid"
                                    }
                                    else {
                                        "Not Valid"
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    If ($_.validated -eq $true -and $_.validatedAt -and $_.validationCycle) {
                                        $expirationDate = ([DateTime]$_.validatedAt).AddMonths($_.validationCycle)
                                        $expirationDate.ToString('MM/dd/yyyy')
                                    }
                                    elseif ($_.expiredAt) {
                                        ([DateTime]$_.expiredAt).ToString('MM/dd/yyyy')
                                    }
                                    else {
                                        "N/A"
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
            </TableControl>
        </View>

        <View>
            <Name>Detailed Locations</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.Location.Details</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader>
                        <Label>Name</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>PrimaryContact</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>PrimaryPhone</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>ShippingContact</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>SecurityContact</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>OperationsContact</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>StreetAddress</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Country</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Tags</Label>
                    </TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
                    <TableRowEntry>
                        <TableColumnItems>
                            <TableColumnItem>
                                <ScriptBlock>"{0} " -f $_.name</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>"{0}" -f (($_.contacts | ? type -eq Primary).name)</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>"{0}" -f (($_.contacts | ? type -eq Primary).phoneNumber)</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>"{0}" -f (($_.contacts | ? type -eq shipping_receiving).name)</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>"{0}" -f (($_.contacts | ? type -eq security).name)</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>"{0}" -f (($_.contacts | ? type -eq operations).name)</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>"{0} {1} {2} {3} {4}" -f (($_.addresses | ? type -eq street).streetAddress),(($_.addresses | ? type -eq street).streetAddress2), (($_.addresses | ? type -eq street).postalCode),(($_.addresses | ? type -eq street).city),(($_.addresses | ? type -eq street).state)</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>"{0}" -f $_.addresses.country</ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.tags -and $_.tags.Count -gt 0) {
                                        ($_.tags | ForEach-Object { "$($_.name)=$($_.value)" }) -join ", "
                                    } else { "" }
                                </ScriptBlock>
                            </TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
            </TableControl>
        </View>

