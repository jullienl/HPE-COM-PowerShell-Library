        <View>
            <Name>Role Assigned Principals</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.Role.Assigned.Principals</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader>
                        <Label>Name</Label>
                        <!-- <Width>25</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Type</Label>
                        <!-- <Width>8</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Email</Label>
                        <!-- <Width>35</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Role</Label>
                        <!-- <Width>35</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Service</Label>
                        <!-- <Width>25</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Scoping</Label>
                        <!-- <Width>30</Width> -->
                    </TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
                    <TableRowEntry>
                        <TableColumnItems>
                            <TableColumnItem>
                                <PropertyName>name</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>type</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>email</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>role_name</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>service_name</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.scopes) {
                                        if ($_.scopes -is [array] -and $_.scopes.Count -gt 0) {
                                            if ($_.scopes[0].scopeName) {
                                                ($_.scopes | ForEach-Object { $_.scopeName }) -join ', '
                                            } else {
                                                $_.scopes -join ', '
                                            }
                                        } else {
                                            'Entire workspace'
                                        }
                                    } else {
                                        'Entire workspace'
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
            </TableControl>
        </View>

        <View>
            <Name>Role Permissions</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.Role.Permissions</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader>
                        <Label>Permission</Label>
                        <!-- <Width>50</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Description</Label>
                        <!-- <Width>60</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Provider</Label>
                        <Width>25</Width>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Scoping</Label>
                        <Width>30</Width>
                    </TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
                    <TableRowEntry>
                        <TableColumnItems>
                            <TableColumnItem>
                                <PropertyName>Permission</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>Description</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>Provider</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.FixedScope -eq $true) {
                                        'Applies to entire workspace'
                                    } elseif ($_.Scopes) {
                                        if ($_.Scopes -is [array] -and $_.Scopes.Count -gt 0) {
                                            if ($_.Scopes[0].scopeName) {
                                                ($_.Scopes | ForEach-Object { $_.scopeName }) -join ', '
                                            } else {
                                                $_.Scopes -join ', '
                                            }
                                        } else {
                                            $_.Scopes.ToString()
                                        }
                                    } else {
                                        'N/A'
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
            </TableControl>
        </View>

