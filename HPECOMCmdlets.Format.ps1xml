                                <ScriptBlock>
                                    switch ($_.connectionType) {
                                        'GATEWAY' { 'Secure Gateway' }
                                        'ONEVIEW' { 'OneView managed' }
                                        'DIRECT'  { 'Direct' }
                                        default   { $_.connectionType }
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
