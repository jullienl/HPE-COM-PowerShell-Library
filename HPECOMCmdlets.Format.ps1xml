                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    switch ($_.connectionType) {
                                        'GATEWAY' { 'Secure Gateway' }
                                        'ONEVIEW' { 'OneView managed' }
                                        'DIRECT'  { 'Direct' }
                                        default   { $_.connectionType }
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                
                                if ($_.criticalNotification -eq $True -and $_.warningNotification -eq $False -and $_.criticalNonServiceNotification -eq $False){
                                    "True"
                                }
                                else {
                                    "False"
                                }
                            
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>

                                    if ($_.criticalNotification -eq $True -and $_.warningNotification -eq $False -and $_.criticalNonServiceNotification -eq $True){
                                        "True"

                                }
                                else {
                                    "False"

                                }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                
                                if ($_.criticalNotification -eq $True -and $_.warningNotification -eq $True -and $_.criticalNonServiceNotification -eq $True){
                                    "True"

                            }
                            else {
                                "False"

                            }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>"{0}" -f $_.healthNotification</ScriptBlock>
                            </TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
            </TableControl>
        </View>

