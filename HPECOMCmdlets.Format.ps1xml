                        <TableColumnItems>
                            <TableColumnItem>
                                <PropertyName>role_name</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <PropertyName>service_name</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.scopes) {
                                        if ($_.scopes -is [array] -and $_.scopes.Count -gt 0) {
                                            if ($_.scopes[0].scopeName) {
                                                ($_.scopes | ForEach-Object { $_.scopeName }) -join ', '
                                            } else {
                                                $_.scopes -join ', '
                                            }
                                        } else {
