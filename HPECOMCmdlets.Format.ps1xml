                        <TableColumnItems>
                            <TableColumnItem>
                                <PropertyName>name</PropertyName>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.oidcIdpConfig) { "OpenID Connect" } elseif ($_.samlIdpConfig) { "SAML" }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    "SSO Connection"
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    $_.AuthenticationPolicy
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
