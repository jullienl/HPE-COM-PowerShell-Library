        <View>
            <Name>Workspace</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.Workspace.AuthenticationPolicy</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader>
                        <Label>Name</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>State</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Domain</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>AuthenticationSource</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Mode</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Created</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>LastUpdated</Label>
                        <!-- <Width>10</Width> -->
                    </TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
                    <TableRowEntry>
                        <TableColumnItems>
                            <TableColumnItem>
                                <ScriptBlock>
                                    $_.name 
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    $_.state.Substring(0,1).ToUpper() + $_.state.Substring(1).ToLower()
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    If ($_.policyType -eq "USER_RECOVERY") { "Recovery Users" } else { $_.condition.domain }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.ssoConnection) {
                                        $_.ssoConnection
                                    } else { 
                                        If ($_.policyType -eq "DOMAIN_EXTERNAL") { "External SSO" } 
                                     }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    If ($_.targets -eq "USER_RECOVERY") { "Local role assignments" } else {
                                        If ($_.targets.authenticationOnlyMode) { "Authentication Only" } else { "Authentication and Authorization" }
                                    }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.createdAt) { ([datetime]$_.createdAt).ToString("MM/dd/yyyy") } else { "" }
                                </ScriptBlock>
                            </TableColumnItem>
                            <TableColumnItem>
                                <ScriptBlock>
                                    if ($_.updatedAt) { ([datetime]$_.updatedAt).ToString("MM/dd/yyyy") } else { "" }
                                </ScriptBlock>
                            </TableColumnItem>
                        </TableColumnItems>
                    </TableRowEntry>
                </TableRowEntries>
            </TableControl>
        </View>

