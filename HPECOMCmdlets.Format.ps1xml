        <View>
            <Name>UserGroup Roles</Name>
            <ViewSelectedBy>
                <TypeName>HPEGreenLake.UserGroup.Roles</TypeName>
            </ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader>
                        <Label>Role</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Service</Label>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>Scope</Label>
                    </TableColumnHeader>
                </TableHeaders>
                <TableRowEntries>
