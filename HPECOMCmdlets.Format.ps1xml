                        <Width>10</Width>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>osType</Label>
                        <Width>10</Width>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>mediaUrl</Label>
                        <Width>10</Width>
                    </TableColumnHeader>
                    <TableColumnHeader>
                        <Label>unattendedInstallationFileUrl</Label>
